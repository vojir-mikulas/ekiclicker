# Zkopíruj do .env (gitignored) a uprav. Vite čte VITE_* při buildu/startu.

# Konzolové cheaty (window.eki.setMoney/setLevel/dropItem/dropChest/dropEgg/unlock).
# Zapnuté ve výchozím stavu (i když proměnná chybí). Vypneš jen explicitně VITE_CHEATS=0,
# pak Vite kód odstraní z bundle. Změna se projeví až po: prod → `npm run build`,
# dev → restart `npm run dev`.
VITE_CHEATS=1
