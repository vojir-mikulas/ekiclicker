# =========================================================================
# Eki Clicker — server konfigurace. Zkopíruj do .env a vyplň.
# =========================================================================

# Postgres připojení. Když není nastaveno, server běží bez DB (lokální režim)
# a /api/* vrací 503 db_unavailable.
DATABASE_URL=postgres://user:password@localhost:5432/ekiclicker

# Port HTTP serveru (default 3000).
PORT=3000

# Tajný klíč pro ověření HMAC podpisu skóre (volitelné). Když není nastaven,
# pole `sig` se ignoruje. Ověření je best-effort — neshoda jen loguje.
HMAC_SECRET=

# Hodnota pro Express 'trust proxy' (default 1 = jedna reverzní proxy).
# Může být i 'true', číslo skoků, nebo CIDR. Viz Express docs.
TRUST_PROXY=1

# Cesta ke zbuildované webové aplikaci (default ../../web/dist relativně k src).
# Když složka neexistuje, statika se neserveruje (dev s Vite).
WEB_DIST=

# Pustit migrace při startu? 'false' je vypne (default zapnuto).
RUN_MIGRATIONS_ON_BOOT=true

# Rate limiting (volitelné — rozumné defaulty). Okno v ms a maxima na IP.
RATE_WINDOW_MS=60000
RATE_GENERAL_MAX=120
RATE_AUTH_MAX=10

# Denní strop nových účtů z jedné IP za 24 h (default 20). Tvrdý blok registrace.
# POZOR: za více reverzními proxy musí sedět TRUST_PROXY (výš), jinak server vidí
# jednu (proxy) IP pro všechny a strop pak zablokuje úplně každého.
IP_DAILY_ACCOUNT_CAP=20
