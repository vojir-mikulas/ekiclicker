{
  "name": "ekiclicker-monorepo",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "release": "sh scripts/release.sh",
    "dev": "concurrently -n web,api -c blue,green \"npm run dev -w @ekiclicker/web\" \"npm run dev -w @ekiclicker/server\"",
    "build": "npm run build -w @ekiclicker/web",
    "start": "npm run start -w @ekiclicker/server",
    "migrate": "npm run migrate -w @ekiclicker/server",
    "lint": "oxlint",
    "balance": "npm run balance -w @ekiclicker/web",
    "smoke": "npm run smoke -w @ekiclicker/web"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "oxlint": "^1.69.0"
  }
}
